{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  automerge: false,
  extends: [
    'github>holidayworking/renovate-config',
    'github>aquaproj/aqua-renovate-config#2.7.5',
    'github>aquaproj/aqua-renovate-config:installer-script#2.7.5(cookbooks/aqua/default.rb)',
  ],
  packageRules: [
    {
      groupName: 'aqua',
      automerge: true,
      matchPackageNames: [
        '/^aquaproj/',
      ],
    },
  ],
}
