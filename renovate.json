{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    ":dependencyDashboard",
    "github>aquaproj/aqua-renovate-config#1.2.0",
    "github>aquaproj/aqua-renovate-config:installer-script#1.2.0(cookbooks/aqua/default.rb)"
